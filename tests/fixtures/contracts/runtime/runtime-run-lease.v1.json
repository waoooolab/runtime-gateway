{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/runtime-run-lease.v1.json",
  "title": "RuntimeRunLeaseViewV1",
  "description": "Run lease projection response for runtime lease lookup endpoints.",
  "type": "object",
  "required": [
    "run_id",
    "lease",
    "device_hub"
  ],
  "properties": {
    "run_id": {
      "type": "string",
      "minLength": 1
    },
    "lease": {
      "oneOf": [
        {
          "type": "null"
        },
        {
          "type": "object",
          "required": [
            "lease_id",
            "task_id",
            "state"
          ],
          "properties": {
            "lease_id": {
              "type": "string",
              "minLength": 1
            },
            "task_id": {
              "type": "string",
              "minLength": 1
            },
            "device_id": {
              "type": [
                "string",
                "null"
              ]
            },
            "state": {
              "type": "string",
              "enum": [
                "active",
                "released",
                "expired",
                "unknown"
              ]
            },
            "transition_error": {
              "type": "string",
              "minLength": 1
            }
          },
          "additionalProperties": true
        }
      ]
    },
    "device_hub": {
      "type": "object",
      "required": [
        "status"
      ],
      "properties": {
        "status": {
          "type": "string",
          "enum": [
            "ok",
            "error",
            "not_bound"
          ]
        },
        "snapshot": {
          "type": "object"
        },
        "error": {
          "type": "string",
          "minLength": 1
        }
      },
      "allOf": [
        {
          "if": {
            "properties": {
              "status": {
                "const": "ok"
              }
            }
          },
          "then": {
            "required": [
              "snapshot"
            ]
          }
        },
        {
          "if": {
            "properties": {
              "status": {
                "const": "error"
              }
            }
          },
          "then": {
            "required": [
              "error"
            ]
          }
        }
      ],
      "additionalProperties": true
    },
    "recommended_poll_after_ms": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    }
  },
  "additionalProperties": true
}

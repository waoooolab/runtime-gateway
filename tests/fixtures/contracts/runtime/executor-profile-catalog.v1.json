{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/executor-profile-catalog.v1.json",
  "title": "ExecutorProfileCatalogV1",
  "description": "Supported executor family/engine/adapter combinations exposed by runtime APIs.",
  "type": "object",
  "required": [
    "items"
  ],
  "properties": {
    "items": {
      "type": "array",
      "minItems": 1,
      "items": {
        "type": "object",
        "required": [
          "family",
          "engines",
          "adapters"
        ],
        "properties": {
          "family": {
            "type": "string",
            "enum": [
              "native_agent",
              "acp",
              "workflow_runtime",
              "compute_runtime"
            ]
          },
          "engines": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "minLength": 1
            }
          },
          "adapters": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "orchestrator",
                "ccb",
                "runtime_api",
                "native"
              ]
            }
          },
          "access_modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "direct",
                "api"
              ]
            }
          },
          "window_modes": {
            "type": "array",
            "minItems": 1,
            "uniqueItems": true,
            "items": {
              "type": "string",
              "enum": [
                "inline",
                "terminal_mux"
              ]
            }
          }
        },
        "additionalProperties": false
      }
    }
  },
  "additionalProperties": false
}

{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/runtime-worker-status.v1.json",
  "title": "RuntimeWorkerStatusV1",
  "description": "Worker lifecycle status projection for runtime orchestration status endpoints.",
  "type": "object",
  "required": [
    "lifecycle_state",
    "is_running",
    "lifecycle_health",
    "queue_depth",
    "last_transition",
    "last_transition_at",
    "last_heartbeat_at",
    "last_heartbeat_age_seconds",
    "is_heartbeat_stale",
    "pool_last_control_counts",
    "pool_last_control_outcome",
    "pool_last_control_signal",
    "ticks_total",
    "drain_calls_total",
    "start_total",
    "stop_total",
    "restart_total",
    "recommended_poll_after_ms"
  ],
  "properties": {
    "lifecycle_state": {
      "type": "string",
      "enum": [
        "running",
        "stopped"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/runtime-worker-status.v1.json#/properties/lifecycle_state/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "is_running": {
      "type": "boolean"
    },
    "lifecycle_health": {
      "type": "string",
      "enum": [
        "healthy",
        "degraded",
        "stopped"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/runtime-worker-status.v1.json#/properties/lifecycle_health/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "queue_depth": {
      "type": "integer",
      "minimum": 0
    },
    "last_transition": {
      "type": [
        "string",
        "null"
      ],
      "enum": [
        "start",
        "stop",
        "restart",
        null
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/runtime-worker-status.v1.json#/properties/last_transition/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "last_transition_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_heartbeat_at": {
      "type": [
        "string",
        "null"
      ],
      "format": "date-time"
    },
    "last_heartbeat_age_seconds": {
      "type": [
        "number",
        "null"
      ],
      "minimum": 0
    },
    "is_heartbeat_stale": {
      "type": "boolean"
    },
    "pool_last_control_counts": {
      "type": "object",
      "required": [
        "queue",
        "defer",
        "reject"
      ],
      "properties": {
        "queue": {
          "type": "integer",
          "minimum": 0
        },
        "defer": {
          "type": "integer",
          "minimum": 0
        },
        "reject": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": false
    },
    "pool_last_control_outcome": {
      "type": "string",
      "enum": [
        "dispatch",
        "queue",
        "defer",
        "reject"
      ],
      "$comment": "SSOT source pointer: jsonschema/runtime/runtime-worker-status.v1.json#/properties/pool_last_control_outcome/enum. Mirror owners must align with openwaoooo/packages/contracts and openwaoooo/packages/contracts-py when applicable."
    },
    "pool_last_control_signal": {
      "type": "object",
      "required": [
        "queue_pending",
        "defer_pending",
        "reject_pending"
      ],
      "properties": {
        "queue_pending": {
          "type": "boolean"
        },
        "defer_pending": {
          "type": "boolean"
        },
        "reject_pending": {
          "type": "boolean"
        }
      },
      "additionalProperties": false
    },
    "ticks_total": {
      "type": "integer",
      "minimum": 0
    },
    "drain_calls_total": {
      "type": "integer",
      "minimum": 0
    },
    "start_total": {
      "type": "integer",
      "minimum": 0
    },
    "stop_total": {
      "type": "integer",
      "minimum": 0
    },
    "restart_total": {
      "type": "integer",
      "minimum": 0
    },
    "recommended_poll_after_ms": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    }
  },
  "additionalProperties": true
}

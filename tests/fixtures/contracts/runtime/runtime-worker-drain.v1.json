{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://waoooolab.dev/contracts/runtime/runtime-worker-drain.v1.json",
  "title": "RuntimeWorkerDrainV1",
  "description": "Worker drain projection response for runtime orchestration drain endpoint.",
  "type": "object",
  "required": [
    "fair",
    "auto_start",
    "max_items",
    "processed",
    "queue_depth_before",
    "queue_depth_after",
    "remaining",
    "should_continue",
    "outcome_counts",
    "anomaly_counts",
    "anomaly_ratio",
    "progressed_ratio",
    "stalled_signal",
    "recommended_poll_after_ms",
    "scheduling_signal",
    "outcomes"
  ],
  "properties": {
    "fair": {
      "type": "boolean"
    },
    "auto_start": {
      "type": "boolean"
    },
    "max_items": {
      "type": "integer",
      "minimum": 1,
      "maximum": 512
    },
    "processed": {
      "type": "integer",
      "minimum": 0
    },
    "queue_depth_before": {
      "type": "integer",
      "minimum": 0
    },
    "queue_depth_after": {
      "type": "integer",
      "minimum": 0
    },
    "remaining": {
      "type": "integer",
      "minimum": 0
    },
    "should_continue": {
      "type": "boolean"
    },
    "outcome_counts": {
      "type": "object",
      "required": [
        "progressed",
        "missing_run",
        "skipped"
      ],
      "properties": {
        "progressed": {
          "type": "integer",
          "minimum": 0
        },
        "missing_run": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "anomaly_counts": {
      "type": "object",
      "required": [
        "missing_run",
        "skipped",
        "total"
      ],
      "properties": {
        "missing_run": {
          "type": "integer",
          "minimum": 0
        },
        "skipped": {
          "type": "integer",
          "minimum": 0
        },
        "total": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    },
    "anomaly_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "progressed_ratio": {
      "type": "number",
      "minimum": 0,
      "maximum": 1
    },
    "stalled_signal": {
      "type": "boolean"
    },
    "recommended_poll_after_ms": {
      "type": "integer",
      "minimum": 100,
      "maximum": 60000
    },
    "scheduling_signal": {
      "type": "object",
      "required": [
        "queue_depth_before",
        "queue_depth_after",
        "processed",
        "max_items",
        "remaining",
        "should_continue",
        "stalled_signal",
        "anomaly_ratio",
        "recommended_poll_after_ms"
      ],
      "properties": {
        "queue_depth_before": {
          "type": "integer",
          "minimum": 0
        },
        "queue_depth_after": {
          "type": "integer",
          "minimum": 0
        },
        "processed": {
          "type": "integer",
          "minimum": 0
        },
        "max_items": {
          "type": "integer",
          "minimum": 1,
          "maximum": 512
        },
        "remaining": {
          "type": "integer",
          "minimum": 0
        },
        "should_continue": {
          "type": "boolean"
        },
        "stalled_signal": {
          "type": "boolean"
        },
        "anomaly_ratio": {
          "type": "number",
          "minimum": 0,
          "maximum": 1
        },
        "recommended_poll_after_ms": {
          "type": "integer",
          "minimum": 100,
          "maximum": 60000
        }
      },
      "additionalProperties": true
    },
    "outcomes": {
      "type": "array",
      "items": {
        "type": "object",
        "required": [
          "outcome",
          "fair",
          "auto_start",
          "leased_run_id",
          "recommended_poll_after_ms"
        ],
        "properties": {
          "outcome": {
            "type": "string",
            "enum": [
              "idle",
              "progressed",
              "missing_run",
              "skipped"
            ]
          },
          "fair": {
            "type": "boolean"
          },
          "auto_start": {
            "type": "boolean"
          },
          "leased_run_id": {
            "type": [
              "string",
              "null"
            ]
          },
          "before_status": {
            "type": "string",
            "minLength": 1
          },
          "after_status": {
            "type": "string",
            "minLength": 1
          },
          "reason": {
            "type": "string",
            "minLength": 1
          },
          "recommended_poll_after_ms": {
            "type": "integer",
            "minimum": 100,
            "maximum": 60000
          }
        },
        "additionalProperties": true
      }
    },
    "lease_renew_signal": {
      "type": "object",
      "required": [
        "attempted",
        "renewed",
        "errors",
        "expired_conflicts",
        "released_conflicts",
        "last_observed_at",
        "total_attempted",
        "total_renewed",
        "total_errors",
        "total_expired_conflicts",
        "total_released_conflicts"
      ],
      "properties": {
        "attempted": {
          "type": "integer",
          "minimum": 0
        },
        "renewed": {
          "type": "integer",
          "minimum": 0
        },
        "errors": {
          "type": "integer",
          "minimum": 0
        },
        "expired_conflicts": {
          "type": "integer",
          "minimum": 0
        },
        "released_conflicts": {
          "type": "integer",
          "minimum": 0
        },
        "last_observed_at": {
          "type": [
            "string",
            "null"
          ],
          "format": "date-time"
        },
        "total_attempted": {
          "type": "integer",
          "minimum": 0
        },
        "total_renewed": {
          "type": "integer",
          "minimum": 0
        },
        "total_errors": {
          "type": "integer",
          "minimum": 0
        },
        "total_expired_conflicts": {
          "type": "integer",
          "minimum": 0
        },
        "total_released_conflicts": {
          "type": "integer",
          "minimum": 0
        }
      },
      "additionalProperties": true
    }
  },
  "additionalProperties": true
}
